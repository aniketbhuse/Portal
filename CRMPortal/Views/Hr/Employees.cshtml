@model List<CRMPortal.Models.MasterEmployee>

@{
    ViewData["Title"] = "Employee Master";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]

        <button class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]

        <button class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

<div class="container-fluid mt-3 top" style="margin-left: -110px;">

    <!-- Summary Card -->

    <div class="row mb-3">

        <div class="col-md-3">

            <div class="card shadow border-0">

                <div class="card-body">

                    <h6>Total Employees</h6>

                    <h2 class="text-primary">

                        @Model.Count

                    </h2>

                </div>

            </div>

        </div>
    </div>

    <!-- Employee Table -->

    <div class="card shadow" style="width: 120%;">

        <div class="card-header bg-primary text-white">

            <h4 class="mb-0">

                Employee Master List

            </h4>

        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-bordered table-hover table-striped align-middle mb-0">

                    <thead class="table-dark">

                        <tr>

                            <th>Action</th>

                            <th>Employee Code</th>

                            <th>First Name</th>

                            <th>Last Name</th>

                            <th>Full Name</th>

                            <th>Email</th>

                            <th>Gender</th>

                            <th>DOB</th>

                            <th>Blood Group</th>

                            <th>Marital Status</th>

                            <th>Mobile</th>

                            <th>Alternate Mobile</th>

                            <th>Emergency Contact Name</th>

                            <th>Emergency Contact</th>

                            <th>Address</th>

                            <th>City</th>

                            <th>State</th>

                            <th>Country</th>

                            <th>Pincode</th>

                            <th>Department</th>

                            <th>Designation</th>

                            <th>Joining Date</th>

                            <th>Employment Type</th>

                            <th>Reporting Manager</th>

                            <th>Work Location</th>

                            <th>Shift</th>

                            <th>Salary</th>

                            <th>Aadhaar</th>

                            <th>PAN</th>

                            <th>Passport</th>

                            <th>Bank</th>

                            <th>Account No.</th>

                            <th>IFSC</th>

                            <th>Status</th>

                            <th>Created</th>

                            <th>Updated</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td style="min-width:140px;">

                                    <a asp-action="EditEmployee"
                                       asp-route-id="@item.EmployeeId"
                                       class="btn btn-warning btn-sm">

                                        Edit

                                    </a>

                                    <a asp-action="DeleteEmployee"
                                       asp-route-id="@item.EmployeeId"
                                       onclick="return confirm('Delete Employee?')"
                                       class="btn btn-danger btn-sm">

                                        Delete

                                    </a>

                                </td>

                                <td>@item.EmployeeCode</td>

                                <td>@item.FirstName</td>

                                <td>@item.LastName</td>

                                <td>@item.FullName</td>

                                <td>@item.Email</td>

                                <td>@item.Gender</td>

                                <td>@item.DateOfBirth</td>

                                <td>@item.BloodGroup</td>

                                <td>@item.MaritalStatus</td>

                                <td>@item.MobileNumber</td>

                                <td>@item.AlternateMobile</td>

                                <td>@item.EmergencyContactName</td>

                                <td>@item.EmergencyContact</td>

                                <td>@item.AddressLine1</td>

                                <td>@item.City</td>

                                <td>@item.State</td>

                                <td>@item.Country</td>

                                <td>@item.Pincode</td>

                                <td>@item.Department</td>

                                <td>@item.Designation</td>

                                <td>@item.JoiningDate</td>

                                <td>@item.EmploymentType</td>

                                <td>@item.ReportingManager</td>

                                <td>@item.WorkLocation</td>

                                <td>@item.Shift</td>

                                <td>₹ @item.Salary.ToString("N2")</td>

                                <td>@item.AadhaarNumber</td>

                                <td>@item.PANNumber</td>

                                <td>@item.PassportNumber</td>

                                <td>@item.BankName</td>

                                <td>@item.AccountNumber</td>

                                <td>@item.IFSCCode</td>

                                <td>

                                    @if (item.EmployeeStatus == "Active")
                                    {
                                        <span class="badge bg-success">

                                            Active

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">

                                            @item.EmployeeStatus

                                        </span>
                                    }

                                </td>

                                <td>@item.CreatedDate.ToString("dd-MM-yyyy")</td>

                                <td>@item.UpdatedDate.ToString("dd-MM-yyyy")</td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<style>

    .card {
        border-radius: 12px;
    }

    .table-responsive {
        overflow-x: auto;
        overflow-y: auto;
        max-height: 75vh;
    }

    .table thead th {
        position: sticky;
        top: 0;
        z-index: 100;
        white-space: nowrap;
    }

    .table td,
    .table th {
        white-space: nowrap;
        vertical-align: middle;
    }

    .table tbody tr:hover {
        background: #eef7ff;
        transition: .2s;
    }

    .badge {
        font-size: 14px;
    }

    .top{
        margin-top: 70px;
    }

</style>