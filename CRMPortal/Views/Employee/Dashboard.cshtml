@{
    ViewData["Title"] = "Employee Dashboard";
}

<div class="container-fluid mt-4">

    <!-- SUCCESS MESSAGE -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">

            @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }

    <!-- ERROR MESSAGE -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">

            @TempData["Error"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }

   
    <!-- UPLOAD FILE SECTION -->
    <div class="card shadow mb-4">

        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">
                Upload CD Excel File
            </h5>

        </div>

        <div class="card-body">

            <form asp-controller="Employee"
                  asp-action="UploadCD"
                  method="post"
                  enctype="multipart/form-data">

                <div class="row">

                    <div class="col-md-10">

                        <input type="file"
                               name="File"
                               class="form-control"
                               accept=".xlsx,.xls" />

                    </div>

                    <div class="col-md-2">

                        <button type="submit"
                                class="btn btn-success w-100">

                            Upload

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- FILE LIST -->
    <div class="card shadow">

        <div class="card-header bg-dark text-white">

            <h5 class="mb-0">
                My Uploaded Files
            </h5>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-hover">

                    <thead class="table-light">

                        <tr>

                            <th>File Name</th>

                            <th>Size (KB)</th>

                            <th>Uploaded Date</th>

                            <th>Action</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (ViewBag.Files != null &&
                             ViewBag.Files.Count > 0)
                        {
                            @foreach (var item in ViewBag.Files)
                            {
                                <tr>

                                    <td>
                                        @item.FileName
                                    </td>

                                    <td>
                                        @(item.FileSize / 1024)
                                    </td>

                                    <td>
                                        @item.UploadedDate.ToString("dd-MMM-yyyy hh:mm tt")
                                    </td>

                                    <td>

                                        <a asp-controller="Employee"
                                           asp-action="DeleteFile"
                                           asp-route-id="@item.FileId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Are you sure you want to delete this file?');">

                                            Delete

                                        </a>

                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="3"
                                    class="text-center text-muted">

                                    No files uploaded yet.

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<style>

    .table-hover tbody tr:hover {
        background-color: #f5f9ff;
        cursor: pointer;
        transition: 0.3s;
    }

    .card {
        border-radius: 10px;
    }

</style>