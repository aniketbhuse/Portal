@{
    ViewData["Title"] = "Apply Leave";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

<div class="container-fluid mt-4">

    <div class="row">

        <!-- LEFT SIDE -->
        <div class="col-md-4">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">
                    <h4>Apply Leave</h4>
                </div>

                <div class="card-body">

                    <form asp-action="ApplyLeave"
                          method="post">

                        <div class="mb-3">

                            <label class="form-label">
                                Leave Type
                            </label>

                            <select class="form-control"
                                    name="LeaveTypeId">

                                <option value="">
                                    Select Leave Type
                                </option>

                                @foreach (var item in ViewBag.LeaveTypes)
                                {
                                    <option value="@item.LeaveTypeId">
                                        @item.LeaveTypeName
                                    </option>
                                }

                            </select>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                From Date
                            </label>

                            <input type="date"
                                   name="FromDate"
                                   class="form-control" 
                                   min="@DateTime.Now.ToString("yyyy-MM-dd")" />

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                To Date
                            </label>

                            <input type="date"
                                   name="ToDate"
                                   class="form-control" 
                                   min="@DateTime.Now.ToString("yyyy-MM-dd")" />

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Reason
                            </label>

                            <textarea class="form-control"
                                      name="Reason"
                                      rows="4"></textarea>

                        </div>

                        <button type="submit"
                                class="btn btn-success w-100">

                            Submit Leave Request

                        </button>

                    </form>

                </div>

            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="col-md-8">

            <div class="card shadow">

                <div class="card-header bg-dark text-white">
                    <h4>My Leave Requests</h4>
                </div>

                <div class="card-body">

                    <div class="table-responsive">

                        <table class="table table-bordered table-hover">

                            <thead class="table-light">

                                <tr>

                                    <th>Leave ID</th>

                                    <th>From Date</th>

                                    <th>To Date</th>

                                    <th>Total Days</th>

                                    <th>Status</th>

                                    <th>Remarks</th>

                                    <th>Applied On</th>

                                </tr>

                            </thead>

                            <tbody>

                                @if (ViewBag.LeaveRequests != null)
                                {
                                    @foreach (var item in ViewBag.LeaveRequests)
                                    {
                                        <tr>

                                            <td>
                                                @item.LeaveRequestId
                                            </td>

                                            <td>
                                                @item.FromDate
                                            </td>

                                            <td>
                                                @item.ToDate
                                            </td>

                                            <td>
                                                @item.TotalDays
                                            </td>

                                            <td>

                                                @if (item.Status == "Pending")
                                                {
                                                    <span class="badge bg-warning text-dark">
                                                        Pending
                                                    </span>
                                                }
                                                else if (item.Status == "Approved")
                                                {
                                                    <span class="badge bg-success">
                                                        Approved
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">
                                                        Rejected
                                                    </span>
                                                }

                                            </td>

                                            <td>

                                                @if (!string.IsNullOrEmpty(item.AdminRemarks))
                                                {
                                                    @item.AdminRemarks
                                                }
                                                else
                                                {
                                                    <span class="text-muted">
                                                        Waiting for approval
                                                    </span>
                                                }

                                            </td>

                                            <td>
                                                @item.CreatedDate.ToString("dd-MMM-yyyy")
                                            </td>

                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>

                                        <td colspan="6"
                                            class="text-center">

                                            No Leave Requests Found

                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    .table-hover tbody tr:hover {
        background-color: #f5f9ff;
        cursor: pointer;
        transition: 0.3s;
    }

</style>