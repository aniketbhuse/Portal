
@model CRMPortal.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MARS CRM Login</title>

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI', sans-serif;
            }

            body {
                background-color: #f4f6f9;
                height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
            }

            .login-container {
                width: 720px;
                background: #ffffff;
                padding: 40px;
                border-radius: 15px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            }

            .logo {
                text-align: center;
                margin-bottom: 30px;
            }

                .logo h1 {
                    color: #1f2937;
                    font-size: 32px;
                    font-weight: 700;
                }

                .logo p {
                    color: #6b7280;
                    margin-top: 5px;
                    font-size: 14px;
                }

            .form-group {
                margin-bottom: 20px;
            }

                .form-group label {
                    display: block;
                    margin-bottom: 8px;
                    color: #374151;
                    font-weight: 600;
                    font-size: 14px;
                }

                .form-group input {
                    width: 100%;
                    padding: 14px;
                    border: 1px solid #d1d5db;
                    border-radius: 8px;
                    font-size: 15px;
                    transition: all 0.3s ease;
                }

                    .form-group input:focus {
                        outline: none;
                        border-color: #2563eb;
                        box-shadow: 0 0 0 3px rgba(37,99,235,0.15);
                    }

            .login-btn {
                width: 100%;
                padding: 14px;
                border: none;
                border-radius: 8px;
                background-color: #2563eb;
                color: white;
                font-size: 16px;
                font-weight: 600;
                cursor: pointer;
                transition: 0.3s;
            }

                .login-btn:hover {
                    background-color: #1d4ed8;
                }

            .error {
                color: #dc2626;
                text-align: center;
                margin-bottom: 15px;
                font-size: 14px;
            }

            .footer {
                text-align: center;
                margin-top: 25px;
                color: #9ca3af;
                font-size: 13px;
            }

    </style>
</head>

<body>

    <div class="login-container">

        <div class="logo">
            <h1>Customer Relationship Management Portal</h1>
            <p>Welcome Back</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div style="color:green;
                text-align:center;
                margin-bottom:15px;">
                @TempData["Success"]
            </div>
        }

        <form method="post">

            <div class="form-group">
                <label>User Name</label>
                <input asp-for="Email" placeholder="Enter your email" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input asp-for="Password"
                       type="password"
                       placeholder="Enter your password" />
            </div>

            <div class="error">
                @ViewBag.Error
            </div>

            <button type="submit" class="login-btn">
                Login
            </button>

            <div style="text-align:center; margin-top:15px;">
                <a asp-controller="Account"
                   asp-action="ForgotPassword"
                   style="text-decoration:none; color:#2563eb; font-size:14px;">
                    Forgot Password?
                </a>
            </div>

        </form>

        <div class="footer">
            © 2026 MARS CRM Portal
        </div>

    </div>

</body>
</html>

