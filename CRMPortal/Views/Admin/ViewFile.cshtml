@model List<List<string>>

@{
    ViewData["Title"] = "View File";
}

<style>

    body {
        background-color: #f5f5f5;
    }

    .dashboard-container {
        width: 100%;
        padding: 10px;
    }

    .stats-card {
        border-radius: 6px;
        padding: 15px;
        color: white;
        margin-bottom: 15px;
    }

    .table-wrapper {
        background: white;
        border: 1px solid #ddd;
        overflow-x: auto;
        overflow-y: auto;
        height: 400px;
        width: 120%;
    }

    .excel-table {
        white-space: nowrap;
        font-size: 13px;
        margin-bottom: 0;
    }

        .excel-table thead th {
            position: sticky;
            top: 0;
            background: #f3f3f3;
            z-index: 10;
            border: 1px solid #ddd;
            font-weight: 600;
        }

        .excel-table td {
            border: 1px solid #ddd;
            padding: 6px;
        }

        .excel-table tr:hover {
            background-color: #f8f9fa;
        }

    .pagination {
        justify-content: flex-end;
        margin-top: 15px;
    }

</style>

<div class="container-fluid dashboard-container" style="margin-left: -95px;">

    <div class="row">

        <div class="col-md-3">

            <div class="stats-card bg-primary">

                <h6>Total Records</h6>

                <h3>
                    @ViewBag.TotalRecords
                </h3>

            </div>

        </div>

        <div class="col-md-3">

            <div class="stats-card bg-success">

                <h6>Total Columns</h6>

                <h3>
                    @ViewBag.TotalColumns
                </h3>

            </div>

        </div>

    </div>

    <div class="table-wrapper">

        <table class="table excel-table">

            <thead>

                <tr>

                    @foreach (var header in ViewBag.HeaderRow)
                    {
                        <th>@header</th>
                    }

                </tr>

            </thead>

            <tbody>

                @foreach (var row in Model)
                {
                    <tr>

                        @foreach (var cell in row)
                        {
                            <td>@cell</td>
                        }

                    </tr>
                }

            </tbody>

        </table>

    </div>

    <nav>

        <ul class="pagination">

            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">

                    <a class="page-link"
                       asp-action="ViewFile"
                       asp-route-id="@ViewBag.FileId"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">

                        Previous

                    </a>

                </li>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                    <a class="page-link"
                       asp-action="ViewFile"
                       asp-route-id="@ViewBag.FileId"
                       asp-route-page="@i">

                        @i

                    </a>

                </li>
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">

                    <a class="page-link"
                       asp-action="ViewFile"
                       asp-route-id="@ViewBag.FileId"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">

                        Next

                    </a>

                </li>
            }

        </ul>

    </nav>

</div>